#%Module1.0
##

## Required internal variables

set             name            m3dc1
set             version         devel
set             root            $env(M3DC1_CODE_DIR)

## List conflicting modules here

conflict $name

## List prerequisite modules here

set             fullname        M3D-C1
set             externalurl     http://w3.pppl.gov/~nferraro/m3dc1.html
set             description     "M3D-C1 is an extended-MHD code"

## Required for "module help ..."

proc ModulesHelp { } {
  global description externalurl
  puts stderr "Description - $description"
  puts stderr "Other Docs  - $externalurl"
}

## Required for "module display ..." and SWDB

module-whatis                   "$description"

## Software-specific settings exported to user environment
#KoKKos kernel failed to build with nvidia, so switch to gnu
if { ! [ is-loaded PrgEnv-gnu/8.6.0 ] } {
  module load PrgEnv-gnu/8.6.0
}
if { ! [ is-loaded cray-hdf5-parallel/1.14.3.7 ] } {
  module load cray-hdf5-parallel/1.14.3.7
}
if { ! [ is-loaded cray-netcdf-hdf5parallel/4.9.2.1 ] } {
  module load cray-netcdf-hdf5parallel/4.9.2.1
}
if { ! [ is-loaded cray-fftw/3.3.10.11 ] } {
  module load cray-fftw/3.3.10.11
}
if { ! [ is-loaded fast-mkl-amd/fast-mkl-amd ] } {
  module load fast-mkl-amd/fast-mkl-amd
}
if { ! [ is-loaded cpu ] } {
  module load cpu
}

setenv          M3DC1_VERSION   $version
setenv          M3DC1_DIR       $root
setenv		M3DC1_ARCH	perlmutter_cpu_gcc
setenv		M3DC1_MPIRUN	srun

prepend-path    PATH             $root/unstructured/_perlmutter_cpu_gcc/bin
prepend-path    IDL_PATH         $root/unstructured/idl
