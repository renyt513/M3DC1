#!/bin/bash
#SBATCH -J pellet
#SBATCH -n 64
#SBATCH --time=00:30:00
#SBATCH -o C1stdout

touch started

# partition mesh
PARTS=16
$M3DC1_MPIRUN -n $PARTS split_smb analytic-2K.smb part.smb $PARTS
echo $? > mesh_partitioned

# Run M3D-C1
$M3DC1_MPIRUN -n $SLURM_NTASKS m3dc1_3d -options_file options_bjacobi.type_mumps

touch finished

