#!/bin/bash
#SBATCH -J KPRAD_2D
#SBATCH -n 48
#SBATCH --time=00:30:00
#SBATCH -o C1stdout

touch started

# partition mesh
PARTS=48
$M3DC1_MPIRUN -n $PARTS split_smb analytic-2K.smb part.smb $PARTS
echo $? > mesh_partitioned

# Run M3D-C1
$M3DC1_MPIRUN -n $SLURM_NTASKS m3dc1_2d -pc_factor_mat_solver_type mumps

touch finished

