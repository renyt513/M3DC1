#!/bin/bash
#SBATCH -J RMP
#SBATCH -n 16
#SBATCH --time=00:30:00
#SBATCH -o C1stdout

touch started

# partition mesh
PARTS=$SLURM_NTASKS
$M3DC1_MPIRUN -n $PARTS split_smb diiid-0.02-2.5-4.0-4K.smb part.smb $PARTS
echo $? > mesh_partitioned


# Run M3D-C1
$M3DC1_MPIRUN -n $SLURM_NTASKS m3dc1_2d_complex -pc_factor_mat_solver_type mumps

touch finished
